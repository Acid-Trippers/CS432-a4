# Copy this file to .env if you want to override defaults.
# Docker Compose will use these values when present.

POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=cs432_db

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secret

# App-level variables used by src/config.py and docker-compose pipeline service.
POSTGRES_URI=postgresql://admin:secret@localhost:5432/cs432_db
MONGO_URI=mongodb://admin:secret@localhost:27017/
MONGO_DB_NAME=cs432_db
API_HOST=http://127.0.0.1:8000

# Dashboard admin password (assignment default)
ADMIN_PASS=admin123
